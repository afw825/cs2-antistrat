# ------------------------------
# Python bytecode / caches
# ------------------------------
__pycache__/
*.py[cod]
*$py.class

# ------------------------------
# Virtual environments
# ------------------------------
.venv/
venv/
env/
ENV/

# ------------------------------
# Packaging / build artifacts
# ------------------------------
build/
dist/
.eggs/
*.egg-info/
*.egg
pip-wheel-metadata/

# ------------------------------
# Test / coverage / type-checker caches
# ------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml

# ------------------------------
# Logs / runtime artifacts
# ------------------------------
*.log
*.pid
*.out
*.err

# ------------------------------
# Local databases and dumps
# ------------------------------
*.sqlite
*.sqlite3
*.db
*.sqlitedb

# ------------------------------
# Environment variables / secrets
# ------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
id_rsa
id_dsa

# Streamlit secrets
.streamlit/secrets.toml

# ------------------------------
# Jupyter / notebooks
# ------------------------------
.ipynb_checkpoints/

# ------------------------------
# IDE / editor artifacts
# ------------------------------
.vscode/
.idea/
*.code-workspace

# ------------------------------
# OS-specific files
# ------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ------------------------------
# Project-local generated or sensitive data
# ------------------------------
data/raw_demos/

# Keep docs and schema files tracked
!docs/
!docs/**
